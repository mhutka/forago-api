# ForaGo Backend - Environment Configuration
# Copy to .env and fill in your actual values (DO NOT COMMIT .env to git!)

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/forago_db

# Supabase (optional for MVP - can use local Postgres first)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_AUDIENCE=authenticated

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345678901234567890
JWT_ALGORITHMS=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY_FILE=
JWT_JWKS_URL=
JWT_EXPIRATION_HOURS=24

# Environment
ENVIRONMENT=development
DEBUG=true
DATA_SOURCE_MODE=db
DB_SSL_MODE=disable
# Supported DB_SSL_MODE values: disable | require | verify-full

# AUTH-TEMP (local development only). Do not set in production.
# AUTH_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://forago.app

# Logging
LOG_LEVEL=INFO
