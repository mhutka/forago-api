# ForaGo Backend - Staging Environment
# Copy to .env on staging host (or map to platform secrets).

# Runtime mode
ENVIRONMENT=production
DATA_SOURCE_MODE=db
DEBUG=false
LOG_LEVEL=INFO

# Database (staging DB only)
DB_HOST=<staging-db-host>
DB_PORT=5432
DB_NAME=<staging-db-name>
DB_USER=<staging-db-user>
DB_PASSWORD=<staging-db-password>

# CORS - include your staging frontend domain
CORS_ORIGINS=https://<staging-frontend-domain>

# Supabase project (staging)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# JWT verification (recommended RS256 + JWKS)
JWT_ALGORITHMS=RS256
JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
JWT_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# Optional explicit audience (if different than SUPABASE_JWT_AUDIENCE)
# JWT_AUDIENCE=authenticated

# Optional alternatives to JWKS (use one strategy only)
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# JWT_PUBLIC_KEY_FILE=/etc/secrets/supabase_public_key.pem

# HS256 fallback (only if your Supabase project uses shared secret signing)
# JWT_ALGORITHMS=HS256
# JWT_SECRET_KEY=<supabase-jwt-secret>
